# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Smart Receipt API
APP_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# Format: mysql+pymysql://username:password@localhost:3306/database_name
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/smart_receipt_db
TEST_DATABASE_URL=mysql+pymysql://username:password@localhost:3306/smart_receipt_db_test

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Replace with a long, random string — never use this placeholder in production
JWT_SECRET_KEY=replace-with-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google Gemini AI ───────────────────────────────────────────────────────────
# Required only for real receipt extraction and translation requests.
# Automated tests use mocks and do not call the Gemini API.
# Leave empty to start the app without AI features.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── File Upload ────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/receipts
UPLOAD_DIRECTORY=uploads/receipts
MAX_RECEIPT_FILE_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend origin, e.g. http://localhost:3000
FRONTEND_URL=
