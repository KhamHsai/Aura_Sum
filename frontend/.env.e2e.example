# E2E environment — copy to .env.e2e and fill in your values.
# NEVER commit .env.e2e (it is in .gitignore).

# Frontend API base URL — must point to the running FastAPI backend
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Base URL used by Playwright to open the frontend
E2E_BASE_URL=http://127.0.0.1:5173
